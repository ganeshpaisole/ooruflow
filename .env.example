# ── Environment Variables ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/ooruflow

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-to-a-long-random-secret

# Firebase Cloud Messaging (get from Firebase Console > Project Settings > Cloud Messaging)
FCM_SERVER_KEY=

# Email (SMTP) — Gmail example; use App Password if 2FA is on
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@ooruflow.com

# Razorpay (get from Razorpay Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=
